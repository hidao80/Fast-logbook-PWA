# Windows (Podman Desktop) — active line
--container-daemon-socket npipe:////./pipe/podman-machine-default
# macOS (Podman machine):
# --container-daemon-socket unix://$HOME/.local/share/containers/podman/machine/podman-machine-default/podman.sock
# Linux (rootless Podman):
# --container-daemon-socket unix:///run/user/1000/podman/podman.sock
-P ubuntu-latest=catthehacker/ubuntu:act-22.04
-P ubuntu-slim=catthehacker/ubuntu:act-22.04
